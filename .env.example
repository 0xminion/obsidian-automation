# Copy to .env and fill in your keys
# cp .env.example .env

# TranscriptAPI (YouTube transcripts)
TRANSCRIPT_API_KEY=your_transcriptapi_key_here

# Supadata (YouTube transcript fallback)
SUPADATA_API_KEY=your_supadata_key_here

# AssemblyAI (transcription)
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# Local whisper fallback (optional)
# TRANSCRIBE_BACKEND=local
# LOCAL_WHISPER_CMD=faster-whisper
# LOCAL_WHISPER_MODEL=large-v3

# Obsidian vault path
# VAULT_PATH=$HOME/MyVault
# OBSIDIAN_VAULT=/path/to/vault

# Agent configuration
# AGENT_CMD=claude -p
# MAX_RETRIES=3

# QMD semantic search
# QMD_CMD=qmd
# QMD_COLLECTION=concepts
# QMD_EMBED_MODEL=Qwen3-Embedding-0.6B-Q8_0.gguf

# Extraction
# EXTRACT_TIMEOUT=45

# Parallelism
# PARALLEL=3
